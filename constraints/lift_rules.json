      "name": "sub-self",
      "match": { "operation": "sub", "identity": "same-value", "rewrite": "replace-with-zero" },
      "variables": ["a"],
      "before": { "binop": "sub", "args": [{ "var": "a" }, { "var": "a" }] },
      "after": { "const": "zero" }
    },
    {
      "name": "mul-zero",
      "match": { "operation": "mul", "identity": "zero", "rewrite": "replace-with-zero" },
      "variables": ["a"],
      "before": { "binop": "mul", "args": [{ "var": "a" }, { "const": "zero" }] },
